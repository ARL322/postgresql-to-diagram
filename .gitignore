```gitignore
# Dependencies
node_modules/

# Build outputs
dist/
build/
.next/
out/

# Logs
*.log

# Environment variables
.env
.env.local
*.env.*

# Editor files
.vscode/
.idea/
*.swp
*.swo
*.tmp

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/
pip-log.txt
pip-delete-this-directory.txt
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.log
.git/
.mypy_cache/
.pytest_cache/
.hypothesis/

# Compiled and binary files
*.o
*.obj
*.exe
*.dll
*.so
*.a
*.out

# OS generated files
.DS_Store
Thumbs.db
ehthumbs.db
Icon?
apidoc/
doc/
docs/

# Coverage reports
coverage/
htmlcov/
*.gcov
*.lcov

# Compressed files
*.zip
*.tar.gz
*.tar.bz2
*.tar.xz
*.gz
*.rar
*.7z
```